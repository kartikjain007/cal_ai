{
  "expo": {
    "name": "Cal AI",
    "slug": "cal-ai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "calai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan food to track nutrition",
        "NSPhotoLibraryUsageDescription": "Pick food photos to analyze",
        "NSHealthShareUsageDescription": "Read and understand health data.",
        "NSHealthUpdateUsageDescription": "Share workout data with other apps."
      }
    },

    "android": {
      "package": "com.satyabrat.calai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECORD_AUDIO"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },

    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Scan food to track nutrition"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick food photos to analyze"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "69d8b7a8-15d9-4512-9436-9d2dd40aa2f7"
      }
    },

    "owner": "satya9005"
  }
}