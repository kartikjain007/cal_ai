// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Example models

model User {
  id                  Int       @id @default(autoincrement())
  email                String    @unique
  passwordHash        String    @map("password_hash")
  name                String?
  role                String    @default("user")
  dailyCalories       Int       @default(2000) @map("daily_calories")
  dailyProtein        Int       @default(150) @map("daily_protein")
  dailyCarbs          Int       @default(250) @map("daily_carbs")
  dailyFats          Int       @default(65) @map("daily_fats")
  age                 Int?
  heightCm            Float?    @map("height_cm")
  currentWeightKg    Float?    @map("current_weight_kg")
  targetWeightKg    Float?    @map("target_weight_kg")
  goalType           String?
  weeklyPaceKg      Float?    @map("weekly_pace_kg")
  targetDate        String?   @map("target_date")
  dietType           String?   @map("diet_type")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime? @map("updated_at") @db.Timestamptz

  meals       Meal[]
  waterLogs   WaterLog[]
  exercises  Exercise[]
  reviewActions ReviewAction[]

  @@map("users")
}

// Human-oversight kill-switch (Art. 14(2)): a durable, admin-controlled flag
// that lets an authorized person stop the AI meal-analysis pipeline without
// a deploy. Key/value rather than a dedicated table per switch since this is
// the first (and, for now, only) one.
model SystemSetting {
  key             String    @id
  value           String
  updatedByUserId Int?      @map("updated_by_user_id")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("system_settings")
}

// Audit trail for human review of AI-flagged records and for kill-switch
// toggles (Art. 14(2) — oversight actions must be traceable to a person).
model ReviewAction {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  reviewerId Int      @map("reviewer_id")
  decision   String
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  reviewer User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([reviewerId])
  @@map("review_actions")
}

model Meal {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  foodName        String?   @map("food_name")
  calories       Int?
  protein        Float?
  carbs          Float?
  fats           Float?
  fiber          Float     @default(0)
  healthScore    Int       @default(5) @map("health_score")
  quantityGrams  Int       @default(100) @map("quantity_grams")
  ingredients    Json      @default("[]")
  mealDescription String?  @map("meal_description")
  mealType       String    @default("snack") @map("meal_type")
  imageBase64    String?   @map("image_base64")
  loggedAt       DateTime?  @map("logged_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  confidence       Float?
  flaggedForReview Boolean @default(false)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@map("meals")
}

model WaterLog {
  id        Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  amountMl Int      @map("amount_ml")
  loggedAt DateTime @map("logged_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  flaggedForReview Boolean @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@map("water_logs")
}

model Exercise {
  id              Int      @id @default(autoincrement())
  userId          Int     @map("user_id")
  exerciseName    String  @map("exercise_name")
  durationMinutes Int     @map("duration_minutes")
  caloriesBurned Int     @map("calories_burned")
  loggedAt        DateTime @map("logged_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  flaggedForReview Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@map("exercises")
}

// Durable counterpart to the console-only `logger` in utils/config.ts
// (Art. 12.2 — traceability/log retention). Every flagged-quality event
// (meal_estimate_flagged, meal_save_flagged, water_log_daily_total_anomaly,
// exercise_log_flagged, today_summary_includes_flagged_meals) is written
// here via utils/eventLog.ts's logEvent(), tagged with the same request_id
// echoed on the response as X-Request-Id, so it survives past the
// request/process lifetime and is retrievable by request ID. Rows older
// than LOG_RETENTION_DAYS (utils/eventLog.ts) are purged by the scheduled
// prune job, giving a bounded 6-month retention window.
model LogEvent {
  id        Int      @id @default(autoincrement())
  event     String
  level     String   @default("info")
  requestId String?  @map("request_id")
  userId    Int?     @map("user_id")
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([requestId])
  @@index([event])
  @@index([createdAt])
  @@map("log_events")
}


